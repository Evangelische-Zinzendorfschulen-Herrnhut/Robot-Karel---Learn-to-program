{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/karel/exercise.schema.json",
  "title": "KarelExercise",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "title",
    "prompt",
    "difficulty",
    "orderIndex",
    "concepts",
    "starterCode",
    "initialWorld",
    "goalWorld",
    "hints",
    "tests",
    "isPublished"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "prompt": {
      "type": "string",
      "minLength": 1
    },
    "difficulty": {
      "enum": ["intro", "easy", "medium", "hard", "challenge"]
    },
    "orderIndex": {
      "type": "integer",
      "minimum": 0
    },
    "concepts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "starterCode": {
      "type": "string"
    },
    "initialWorld": {
      "$ref": "#/$defs/karelWorld"
    },
    "goalWorld": {
      "$ref": "#/$defs/karelWorld"
    },
    "hints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/hint"
      }
    },
    "tests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/exerciseTest"
      }
    },
    "isPublished": {
      "type": "boolean"
    }
  },
  "$defs": {
    "hint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["body"],
      "properties": {
        "title": {
          "type": "string"
        },
        "body": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "exerciseTest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "isHidden", "orderIndex", "initialWorld", "goalWorld"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "isHidden": {
          "type": "boolean"
        },
        "orderIndex": {
          "type": "integer",
          "minimum": 0
        },
        "initialWorld": {
          "$ref": "#/$defs/karelWorld"
        },
        "goalWorld": {
          "$ref": "#/$defs/karelWorld"
        }
      }
    },
    "karelWorld": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rows", "cols", "karel", "beepers", "walls"],
      "properties": {
        "rows": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "cols": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "karel": {
          "$ref": "#/$defs/karelState"
        },
        "beepers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/beeperPile"
          }
        },
        "walls": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/wallSegment"
          }
        }
      }
    },
    "position": {
      "type": "object",
      "required": ["row", "col"],
      "properties": {
        "row": {
          "type": "integer",
          "minimum": 1
        },
        "col": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "karelState": {
      "allOf": [
        {
          "$ref": "#/$defs/position"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["row", "col", "direction"],
          "properties": {
            "row": {
              "type": "integer",
              "minimum": 1
            },
            "col": {
              "type": "integer",
              "minimum": 1
            },
            "direction": {
              "enum": ["north", "east", "south", "west"]
            },
            "beeperBag": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      ]
    },
    "beeperPile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["row", "col", "count"],
      "properties": {
        "row": {
          "type": "integer",
          "minimum": 1
        },
        "col": {
          "type": "integer",
          "minimum": 1
        },
        "count": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "wallSegment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["row", "col", "edge"],
      "properties": {
        "row": {
          "type": "integer",
          "minimum": 1
        },
        "col": {
          "type": "integer",
          "minimum": 1
        },
        "edge": {
          "enum": ["north", "east", "south", "west"]
        }
      }
    }
  }
}
